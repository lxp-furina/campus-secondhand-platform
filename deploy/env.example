# 复制为 deploy/env 或在 systemd / 启动脚本中设置
# Linux: source deploy/env && java -jar ...
#
# 部署架构：只需在一台「服务器」上跑 MySQL + Java + Nginx
# 其他电脑/手机只需浏览器访问 http://服务器IP，无需安装本项目

SPRING_PROFILES_ACTIVE=prod

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=campus_secondhand
DB_USERNAME=root
DB_PASSWORD=123456

JWT_SECRET=please-change-this-jwt-secret-in-production
UPLOAD_PATH=/var/www/campus-secondhand/uploads
CORS_ALLOWED_ORIGINS=*

# 可选：通义千问 AI 审核
DASHSCOPE_API_KEY=
